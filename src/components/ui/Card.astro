---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = true } = Astro.props;

const hoverClasses = hover ? 'hover:shadow-md hover:-translate-y-0.5 transition-all duration-300' : '';
---

<div class:list={['bg-white border border-neutral-200 rounded-lg shadow-sm overflow-hidden', hoverClasses, className]}>
  <slot />
</div>
