---
/**
 * Hero — Photo plein ecran, overlay, H1 centre, CTAs
 * Fond : image + overlay bg-black/40
 * Contenu lu depuis src/content/hero/index.json
 */
import { getHero } from '@data/content';

const hero = getHero();
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src={hero.image}
      alt={hero.imageAlt}
      class="w-full h-full object-cover"
      fetchpriority="high"
      data-cms-field="hero.image" data-cms-type="image"
    />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center bg-black/25 backdrop-blur-sm px-3 py-1 rounded-full text-white/90 text-sm mb-6">
      <svg class="w-4 h-4 text-accent-400 mr-1.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
      <span data-cms-field="hero.badgeText" data-cms-type="text">{hero.badgeText}</span>
    </div>

    <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6" data-cms-field="hero.title" data-cms-type="text">
      {hero.title}
    </h1>

    <p class="intro-text text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8 leading-relaxed" data-cms-field="hero.subtitle" data-cms-type="text">
      {hero.subtitle}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={hero.ctaPrimaryHref} class="bg-accent-600 text-white font-semibold py-3 px-8 rounded hover:bg-accent-700 transition-colors min-h-[44px] inline-flex items-center justify-center text-lg">
        {hero.ctaPrimary}
      </a>
      <a href={hero.ctaSecondaryHref} class="border-2 border-white text-white font-semibold py-3 px-8 rounded hover:bg-white/10 transition-colors min-h-[44px] inline-flex items-center justify-center text-lg">
        {hero.ctaSecondary}
      </a>
    </div>

    <!-- Reassurance -->
    <p class="mt-6 text-white/90 text-sm" data-cms-field="hero.reassurance" data-cms-type="text">
      {hero.reassurance}
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
