---
/**
 * Contact / Réservation — Fond vert forêt, formulaire
 * Fond : primary-900
 */
import { business } from '@data/business';
---

<section id="contact" class="py-16 md:py-24 bg-primary-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="md:flex md:gap-12">
      <!-- Formulaire -->
      <div class="md:w-3/5 mb-10 md:mb-0">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-2">
          Réservez votre séjour au Refuge
        </h2>
        <p class="text-white/90 mb-8">
          Nous vous répondons sous 24 heures. Pour une réservation restaurant, appelez-nous directement.
        </p>

        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
          <input type="hidden" name="access_key" value="VOTRE_CLE_WEB3FORMS" />
          <input type="hidden" name="redirect" value={`${business.siteUrl}/merci`} />
          <input type="hidden" name="subject" value="Nouvelle demande — Le Refuge" />
          <input type="hidden" name="from_name" value="Le Refuge — Site web" />
          <input type="hidden" name="ccemail" value="marc@muller.im" />
          <!-- Honeypot -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-white/90 text-sm font-medium mb-1">Nom *</label>
              <input type="text" id="name" name="name" required aria-required="true"
                class="w-full px-4 py-3 rounded bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent min-h-[44px]"
                placeholder="Votre nom" />
            </div>
            <div>
              <label for="email" class="block text-white/90 text-sm font-medium mb-1">Email *</label>
              <input type="email" id="email" name="email" required aria-required="true"
                class="w-full px-4 py-3 rounded bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent min-h-[44px]"
                placeholder="votre@email.fr" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="phone" class="block text-white/90 text-sm font-medium mb-1">Téléphone</label>
              <input type="tel" id="phone" name="phone"
                class="w-full px-4 py-3 rounded bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent min-h-[44px]"
                placeholder="06 00 00 00 00" />
            </div>
            <div>
              <label for="type" class="block text-white/90 text-sm font-medium mb-1">Type de demande *</label>
              <select id="type" name="type" required aria-required="true"
                class="w-full px-4 py-3 rounded bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent min-h-[44px]">
                <option value="" class="text-neutral-800">Choisir...</option>
                <option value="chambre" class="text-neutral-800">Chambre d'hôtes</option>
                <option value="gite" class="text-neutral-800">Gîte</option>
                <option value="restaurant-groupe" class="text-neutral-800">Restaurant — groupe</option>
                <option value="autre" class="text-neutral-800">Autre</option>
              </select>
            </div>
          </div>

          <div>
            <label for="dates" class="block text-white/90 text-sm font-medium mb-1">Dates souhaitées</label>
            <input type="text" id="dates" name="dates"
              class="w-full px-4 py-3 rounded bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent min-h-[44px]"
              placeholder="Ex : du 15 au 18 juillet" />
          </div>

          <div>
            <label for="message" class="block text-white/90 text-sm font-medium mb-1">Votre message *</label>
            <textarea id="message" name="message" rows="4" required aria-required="true"
              class="w-full px-4 py-3 rounded bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent resize-y"
              placeholder="Précisez votre demande..."></textarea>
          </div>

          <p class="text-white/90 text-xs">
            Vos données sont utilisées uniquement pour traiter votre demande. Elles ne sont ni partagées ni revendues. Conformément au RGPD, vous pouvez demander leur suppression à tout moment. <a href="/politique-confidentialite" class="underline hover:text-accent-400 transition-colors">Politique de confidentialité</a>
          </p>

          <button type="submit"
            class="bg-accent-600 text-white font-semibold py-3 px-8 rounded hover:bg-accent-700 transition-colors min-h-[44px] w-full sm:w-auto">
            Envoyer ma demande
          </button>
        </form>
      </div>

      <!-- Infos contact -->
      <aside class="md:w-2/5">
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 md:p-8">
          <h3 class="font-heading text-xl font-semibold text-white mb-6">Coordonnées</h3>

          <div class="space-y-4 text-white/90">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <address class="not-italic">
                <p>{business.address.street}</p>
                <p>{business.address.zip} {business.address.city}</p>
              </address>
            </div>

            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <div>
                <a href={`tel:${business.phone.replace(/\s/g, '')}`} class="hover:text-accent-400 transition-colors">{business.phone}</a>
                <br />
                <a href={`tel:${business.phone2!.replace(/\s/g, '')}`} class="hover:text-accent-400 transition-colors">{business.phone2}</a>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <a href={`mailto:${business.email}`} class="hover:text-accent-400 transition-colors">{business.email}</a>
            </div>
          </div>

          <!-- Google Maps link -->
          <a href={business.socials.googleMaps}
             target="_blank"
             rel="noopener noreferrer"
             class="mt-6 block bg-white/10 hover:bg-white/20 rounded-lg p-4 text-center transition-colors min-h-[44px]">
            <span class="text-white font-medium">Voir sur Google Maps</span>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>
