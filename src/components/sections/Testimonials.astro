---
/**
 * Temoignages — Fond creme, cards citations
 * Fond : secondary-50
 * Contenu lu depuis src/content/testimonials/ (collection) + testimonials-meta (singleton)
 */
import { getCollection } from 'astro:content';
import { getTestimonialsMeta } from '@data/content';

const testimonials = await getCollection('testimonials');
const meta = getTestimonialsMeta();
---

<section class="py-16 md:py-24 bg-secondary-50" data-cms-field="testimonials" data-cms-type="collection">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary-900 mb-4" data-cms-field="testimonials-meta.title" data-cms-type="text">
        {meta.title}
      </h2>
      <div class="flex flex-wrap justify-center gap-6 md:gap-10 mt-6">
        {meta.stats.map((stat) => (
          <div class="text-center">
            <span class="block text-3xl font-bold text-accent-600">{stat.value}</span>
            <span class="text-sm text-neutral-600">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map(({ id, data }) => (
        <article class="bg-white rounded-lg p-6 shadow-sm">
          <!-- Stars -->
          <div class="flex gap-1 mb-3" aria-label={`${data.rating} étoiles sur 5`}>
            {Array.from({ length: data.rating }).map(() => (
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <blockquote class="faq-answer text-neutral-700 italic mb-4 leading-relaxed" data-cms-field={`testimonials.${id}.quote`} data-cms-type="text">
            "{data.quote}"
          </blockquote>
          <footer class="text-sm">
            <span class="font-semibold text-neutral-800" data-cms-field={`testimonials.${id}.author`} data-cms-type="text">{data.author}</span>
            <span class="text-neutral-500"> · <span data-cms-field={`testimonials.${id}.context`} data-cms-type="text">{data.context}</span> ({data.source})</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
