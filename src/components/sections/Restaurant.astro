---
/**
 * Restaurant — Fond creme, carte en tableau, producteurs
 * Fond : secondary-50
 * Contenu lu depuis src/content/restaurant/index.json
 */
import { getRestaurant } from '@data/content';

const r = getRestaurant();
---

<section id="restaurant" class="py-16 md:py-24 bg-secondary-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary-900 mb-4" data-cms-field="restaurant.title" data-cms-type="text">
        {r.title}
      </h2>
      <p class="text-neutral-700 max-w-2xl mx-auto text-lg" data-cms-field="restaurant.subtitle" data-cms-type="text">
        {r.subtitle}
      </p>
    </div>

    <!-- Menu -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <!-- Entrees -->
      <div class="bg-white rounded-lg p-6 md:p-8 shadow-sm">
        <h3 class="font-heading text-xl font-semibold text-secondary-700 mb-4">Entrées</h3>
        <ul class="space-y-3">
          {r.entrees.map((item) => (
            <li class="flex justify-between items-baseline gap-4">
              <span class="text-neutral-800">{item.name}</span>
              <span class="text-secondary-600 font-semibold whitespace-nowrap">{item.price}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Plats -->
      <div class="bg-white rounded-lg p-6 md:p-8 shadow-sm">
        <h3 class="font-heading text-xl font-semibold text-secondary-700 mb-4">Plats</h3>
        <ul class="space-y-3">
          {r.plats.map((item) => (
            <li class="flex justify-between items-baseline gap-4">
              <span class="text-neutral-800">{item.name}</span>
              <span class="text-secondary-600 font-semibold whitespace-nowrap">{item.price}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Desserts -->
      <div class="bg-white rounded-lg p-6 md:p-8 shadow-sm">
        <h3 class="font-heading text-xl font-semibold text-secondary-700 mb-4">{r.dessertsTitle}</h3>
        <ul class="space-y-3">
          {r.desserts.map((dessert) => (
            <li class="text-neutral-800">{dessert}</li>
          ))}
        </ul>
      </div>

      <!-- Menus -->
      <div class="bg-primary-900 text-white rounded-lg p-6 md:p-8">
        <h3 class="font-heading text-xl font-semibold mb-4">Nos menus</h3>
        <div class="space-y-4">
          {r.menus.map((menu, i) => (
            <div class={i < r.menus.length - 1 ? 'border-b border-white/20 pb-3' : ''}>
              <div class="flex justify-between items-baseline">
                <span class="font-semibold">{menu.name}</span>
                <span class="text-accent-400 font-bold text-lg">{menu.price}</span>
              </div>
              <p class="text-white/90 text-sm mt-1">{menu.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Producteurs -->
    <div class="bg-white rounded-lg p-6 md:p-8 shadow-sm">
      <h3 class="font-heading text-2xl font-semibold text-primary-900 mb-2" data-cms-field="restaurant.producteursTitle" data-cms-type="text">{r.producteursTitle}</h3>
      <p class="text-neutral-600 mb-6" data-cms-field="restaurant.producteursSubtitle" data-cms-type="text">{r.producteursSubtitle}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h4 class="font-semibold text-secondary-700 mb-3">En cuisine</h4>
          <ul class="space-y-2 text-neutral-700 text-sm">
            {r.producteursEnCuisine.map((p) => (
              <li>{p}</li>
            ))}
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-secondary-700 mb-3">Au bar</h4>
          <ul class="space-y-2 text-neutral-700 text-sm">
            {r.producteursAuBar.map((p) => (
              <li>{p}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Horaires + CTA -->
    <div class="mt-8 text-center">
      <p class="text-neutral-700 mb-2" data-cms-field="restaurant.horaires" data-cms-type="text">{r.horaires}</p>
      <p class="text-secondary-600 font-medium mb-4" data-cms-field="restaurant.note" data-cms-type="text">{r.note}</p>
      <a href="#contact" class="inline-flex items-center justify-center bg-accent-600 text-white font-semibold py-3 px-8 rounded hover:bg-accent-700 transition-colors min-h-[44px]">
        {r.ctaText}
      </a>
    </div>
  </div>
</section>
