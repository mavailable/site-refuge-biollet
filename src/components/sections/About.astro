---
/**
 * A propos — Fond vert foret, texte blanc
 * Fond : primary-900
 * Contenu lu depuis src/content/about/index.json
 */
import { getAbout } from '@data/content';

const about = getAbout();
---

<section id="apropos" class="py-16 md:py-24 bg-primary-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="md:flex md:items-start md:gap-12">
      <!-- Text -->
      <div class="md:w-3/5 mb-10 md:mb-0">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6" data-cms-field="about.title" data-cms-type="text">
          {about.title}
        </h2>
        <div class="text-white/90 space-y-4 text-lg leading-relaxed" data-cms-field="about.paragraphs" data-cms-type="richtext">
          {about.paragraphs.map((p, i) => (
            <>
              <p set:html={p.replace(/&nbsp;/g, '\u00a0').replace(/\u00a0:/g, '\u00a0:')} />
              {i === about.quotePosition - 1 && about.quote && (
                <blockquote class="border-l-4 border-accent-400 pl-4 italic text-white">
                  "{about.quote}"
                </blockquote>
              )}
            </>
          ))}
        </div>
      </div>

      <!-- Sidebar: a proximite -->
      <aside class="md:w-2/5">
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 md:p-8">
          <h3 class="font-heading text-xl font-semibold text-white mb-4" data-cms-field="about.proximityTitle" data-cms-type="text">
            {about.proximityTitle}
          </h3>
          <ul class="space-y-3">
            {about.proximityItems.map((item) => (
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a href={`https://www.google.com/maps/place/Le+refuge`} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 font-medium transition-colors min-h-[44px]">
            Voir sur Google Maps
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>
