---
/**
 * Gite — Image gauche + texte droite
 * Fond : neutral-50
 * Contenu lu depuis src/content/gite/index.json
 */
import { getGite } from '@data/content';

const g = getGite();
---

<section id="gite" class="py-16 md:py-24 bg-neutral-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="md:flex md:items-center md:gap-12">
      <!-- Image -->
      <div class="md:w-1/2 mb-8 md:mb-0">
        <img src={g.image} alt={g.imageAlt} class="w-full h-72 md:h-96 object-cover rounded-lg" loading="lazy" data-cms-field="gite.image" data-cms-type="image" />
      </div>

      <!-- Content -->
      <div class="md:w-1/2">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary-900 mb-4" data-cms-field="gite.title" data-cms-type="text">
          {g.title}
        </h2>
        <p class="text-neutral-700 text-lg leading-relaxed mb-6" data-cms-field="gite.description" data-cms-type="richtext">
          {g.description}
        </p>

        <!-- Tarifs -->
        <div class="bg-white rounded-lg p-5 shadow-sm mb-6">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-3xl font-bold text-accent-600">{g.priceNight}</span>
            <span class="text-neutral-600">{g.priceNightNote}</span>
          </div>
          <ul class="text-sm text-neutral-700 space-y-1">
            {g.priceDetails.map((detail) => (
              <li>{detail}</li>
            ))}
            <li class="text-primary-700 font-medium">{g.petsNote}</li>
          </ul>
        </div>

        <a href="#contact" class="inline-flex items-center justify-center bg-accent-600 text-white font-semibold py-3 px-8 rounded hover:bg-accent-700 transition-colors min-h-[44px]">
          {g.ctaText}
        </a>
      </div>
    </div>
  </div>
</section>
