---
/**
 * Galerie — Grille masonry
 * Fond : white
 */
const images = [
  { src: '/images/accueil-principale.jpg', alt: 'Le Refuge, maison d\'hôtes en pierre dans la campagne des Combrailles', span: 'col-span-2 row-span-2' },
  { src: '/images/plat-entree-salade.webp', alt: 'Entrée du Refuge — salade de saison avec rillettes et fleurs comestibles', span: '' },
  { src: '/images/plat-dessert-pommes.webp', alt: 'Dessert du Refuge — pommes rôties et crumble au chocolat', span: '' },
  { src: '/images/chaambre.webp', alt: 'Suite Bonsai — chambre avec murs en pierre et parquet', span: '' },
  { src: '/images/restaurant.jpg', alt: 'Salle du restaurant Le Refuge avec tables dressées', span: '' },
  { src: '/images/jardin.webp', alt: 'Jardin du Refuge avec potager en permaculture', span: 'col-span-2 row-span-2' },
  { src: '/images/plat-truite.webp', alt: 'Truite aux amandes et purée de potimarron, légumes du jardin', span: '' },
  { src: '/images/plat-mijote.webp', alt: 'Mijoté de bœuf aux légumes et pommes de terre des Combrailles', span: '' },
  { src: '/images/chambre3.webp', alt: 'Chambre Capucine — lit en bois, murs en pierre, serviettes', span: '' },
  { src: '/images/maison-neige.jpg', alt: 'Le Refuge sous la neige en hiver dans les Combrailles', span: '' },
  { src: '/images/dessert-crepe.webp', alt: 'Crêpe aux pommes caramélisées et chantilly maison', span: '' },
  { src: '/images/gite-exterieur.jpg', alt: 'Vue extérieure du Refuge, jardin et terrasse sous les arbres', span: '' },
];
---

<section id="galerie" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary-900 mb-4">
        Le Refuge en images
      </h2>
      <p class="text-neutral-700 text-lg">
        La maison, le jardin, nos plats — un aperçu de ce qui vous attend.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      {images.map((img) => (
        <div class:list={['overflow-hidden rounded-lg', img.span]}>
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
