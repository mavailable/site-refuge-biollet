---
/**
 * Chambres d'hotes — Fond blanc, cards horizontales
 * Fond : white
 * Contenu lu depuis src/content/chambres/index.json
 */
import { getChambres } from '@data/content';

const ch = getChambres();
const bgColors = ['bg-primary-50', 'bg-secondary-50', 'bg-primary-50'];
---

<section id="chambres" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary-900 mb-4">
        {ch.title}
      </h2>
      <p class="text-neutral-700 max-w-2xl mx-auto text-lg">
        {ch.subtitle}
      </p>
    </div>

    <div class="space-y-6">
      {ch.rooms.map((room, i) => (
        <article class:list={[bgColors[i] || 'bg-primary-50', 'rounded-lg overflow-hidden md:flex', i % 2 === 1 ? 'md:flex-row-reverse' : '']}>
          <div class="md:w-2/5 h-56 md:h-auto">
            <img src={room.image} alt={room.imageAlt} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-6 md:p-8 md:w-3/5 flex flex-col justify-center">
            <h3 class="font-heading text-2xl font-semibold text-primary-900 mb-2">{room.name}</h3>
            <p class="text-neutral-700 mb-4">
              {room.description}
            </p>
            <div class="flex flex-wrap items-center gap-3">
              <span class="bg-accent-600 text-white font-bold py-1.5 px-4 rounded text-sm">{room.priceNight}</span>
              <span class="text-neutral-600 text-sm">{room.priceWeek}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 text-center text-sm text-neutral-600">
      <p>{ch.frais}</p>
      <p class="mt-1 font-medium text-primary-700">{ch.groupe}</p>
    </div>
  </div>
</section>
