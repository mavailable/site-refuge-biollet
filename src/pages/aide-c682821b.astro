---
import BaseLayout from '@layouts/BaseLayout.astro';

const keystatic = 'https://keystatic.cloud/teams/web-factory/projects/refuge-biollet';
const branch = '/branch/master';
const cmsBase = `${keystatic}${branch}`;

const collections = [
  {
    slug: 'testimonials',
    label: 'Témoignages',
    icon: '💬',
    count: 3,
    fields: ['Auteur', 'Citation', 'Contexte', 'Source', 'Note'],
    canAdd: true,
  },
  {
    slug: 'faq',
    label: 'Questions fréquentes',
    icon: '❓',
    count: 6,
    fields: ['Question', 'Réponse', 'Ordre'],
    canAdd: true,
  },
  {
    slug: 'services',
    label: 'Services / Prestations',
    icon: '🍽️',
    count: 0,
    fields: ['Titre', 'Description', 'Prix', 'Ordre'],
    canAdd: true,
  },
];

const singletons = [
  {
    slug: 'site-info',
    label: 'Informations du site',
    icon: 'ℹ️',
    description: 'Nom, description, téléphone, email, adresse',
  },
  {
    slug: 'hero',
    label: 'Accueil (Hero)',
    icon: '🏠',
    description: 'Titre principal, sous-titre, boutons, réassurance',
  },
  {
    slug: 'about',
    label: 'À propos',
    icon: '👩‍🍳',
    description: 'Texte à propos, lieux à proximité',
  },
  {
    slug: 'contact',
    label: 'Contact / Réservation',
    icon: '📩',
    description: 'Titre, sous-titre, bouton, mention RGPD',
  },
];

const googleBusinessUrl = 'https://business.google.com';
const googleMapsUrl = 'https://www.google.com/maps/place/Le+refuge';
const googleReviewUrl = 'https://search.google.com/local/writereview?placeid=ChIJpJHE2LHsxMd6';
const umamiShareUrl = 'UMAMI_SHARE_URL';
---

<BaseLayout
  title="Espace privé — Le Refuge"
  description="Tableau de bord pour gérer votre site Le Refuge."
  noindex={true}
>
  <!-- Sticky tabs -->
  <nav class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-neutral-200 px-4">
    <div class="max-w-5xl mx-auto flex items-center justify-between h-14">
      <div class="flex gap-1">
        <button class="tab-btn text-sm font-medium px-3 py-1.5 rounded-full transition-colors text-primary-700 bg-primary-50" data-index="0">
          Modifier le site
        </button>
        <button class="tab-btn text-sm font-medium px-3 py-1.5 rounded-full transition-colors text-neutral-500" data-index="1">
          Fiche Google
        </button>
        <button class="tab-btn text-sm font-medium px-3 py-1.5 rounded-full transition-colors text-neutral-500" data-index="2">
          Statistiques
        </button>
      </div>
      <span class="hidden sm:block text-sm text-neutral-500">Espace privé — Manon & François</span>
    </div>
  </nav>

  <!-- Swipeable panels -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-ms-overflow-style:none; scrollbar-width:none;">

    <!-- Panel 1 — Modifier le site -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0 px-4 py-8">
      <div class="max-w-5xl mx-auto">
        <div class="mb-8">
          <h1 class="font-heading text-2xl md:text-3xl font-bold text-primary-900 mb-2">Modifier le site</h1>
          <p class="text-neutral-600 mb-4">
            1. Cliquez sur la rubrique à modifier · 2. Faites vos changements · 3. Cliquez "Save" — le site se met à jour automatiquement.
          </p>
          <a href={`${cmsBase}`}
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center gap-2 bg-accent-600 text-white font-semibold py-2.5 px-5 rounded hover:bg-accent-700 transition-colors min-h-[44px] text-sm">
            Modifier mes contenus
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>

        <!-- Collections -->
        <h2 class="font-heading text-lg font-semibold text-primary-900 mb-3">Rubriques (ajout & suppression possibles)</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
          {collections.map(col => (
            <a href={`${cmsBase}/collection/${col.slug}`}
               target="_blank"
               rel="noopener noreferrer"
               class="block bg-white border border-neutral-200 rounded-lg p-5 hover:shadow-md hover:-translate-y-0.5 transition-all">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xl">{col.icon}</span>
                <h3 class="font-semibold text-neutral-800">{col.label}</h3>
                <span class="ml-auto bg-primary-100 text-primary-700 text-xs font-bold px-2 py-0.5 rounded-full">{col.count}</span>
              </div>
              <div class="flex flex-wrap gap-1">
                {col.fields.map(f => (
                  <span class="text-xs bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">{f}</span>
                ))}
              </div>
            </a>
          ))}
        </div>

        <!-- Singletons -->
        <h2 class="font-heading text-lg font-semibold text-primary-900 mb-3">Pages fixes (modification uniquement)</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          {singletons.map(s => (
            <a href={`${cmsBase}/singleton/${s.slug}`}
               target="_blank"
               rel="noopener noreferrer"
               class="block bg-white border border-neutral-200 rounded-lg p-4 hover:shadow-md hover:-translate-y-0.5 transition-all">
              <div class="flex items-center gap-2 mb-1">
                <span>{s.icon}</span>
                <h3 class="font-semibold text-neutral-800 text-sm">{s.label}</h3>
              </div>
              <p class="text-xs text-neutral-500">{s.description}</p>
            </a>
          ))}
        </div>

        <!-- Conseils -->
        <div class="bg-primary-50 rounded-lg p-4 text-sm text-primary-800">
          <strong>Conseils :</strong> Après chaque modification, cliquez "Save" en haut à droite. Si vous faites une erreur, les versions précédentes sont récupérables. Pour toute question : <a href="mailto:marc@muller.im" class="underline">marc@muller.im</a>
        </div>
      </div>
    </section>

    <!-- Panel 2 — Fiche Google -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0 px-4 py-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-900 mb-6">Fiche Google</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <!-- Gérer la fiche -->
          <div class="bg-white border border-neutral-200 rounded-lg p-6">
            <h3 class="font-semibold text-neutral-800 mb-2">Gérer votre fiche</h3>
            <p class="text-sm text-neutral-600 mb-4">Modifiez vos horaires, photos et informations directement sur Google.</p>
            <a href={googleBusinessUrl}
               target="_blank"
               rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-primary-700 text-white font-semibold py-2.5 px-5 rounded hover:bg-primary-800 transition-colors min-h-[44px] text-sm">
              Google Business Profile
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>

          <!-- Demander un avis -->
          <div class="bg-white border border-neutral-200 rounded-lg p-6">
            <h3 class="font-semibold text-neutral-800 mb-2">Demander un avis</h3>
            <p class="text-sm text-neutral-600 mb-3">Copiez ce lien et envoyez-le à vos clients satisfaits :</p>
            <div class="flex gap-2">
              <input
                id="review-link"
                type="text"
                readonly
                value={googleMapsUrl}
                class="flex-1 px-3 py-2 bg-neutral-50 border border-neutral-200 rounded text-sm text-neutral-700 min-h-[44px]"
              />
              <button
                id="copy-btn"
                class="bg-accent-600 text-white font-semibold px-4 py-2 rounded hover:bg-accent-700 transition-colors min-h-[44px] text-sm whitespace-nowrap"
              >
                Copier
              </button>
            </div>
            <p id="copy-feedback" class="text-xs text-primary-600 mt-1 hidden">Lien copié !</p>
          </div>
        </div>

        <!-- Astuces -->
        <div class="bg-secondary-50 rounded-lg p-4 text-sm text-secondary-800">
          <strong>Astuces pour plus d'avis :</strong> Demandez après un repas réussi ou un séjour agréable. Un SMS avec le lien fonctionne mieux qu'un email. Pensez à répondre à chaque avis (même positif) — ça rassure les futurs clients.
        </div>
      </div>
    </section>

    <!-- Panel 3 — Statistiques -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0 px-4 py-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-900 mb-6">Statistiques du site</h2>

        <!-- Desktop : iframe -->
        <div class="hidden md:block bg-white border border-neutral-200 rounded-lg overflow-hidden mb-4">
          <iframe
            src={umamiShareUrl}
            title="Statistiques Le Refuge"
            class="w-full border-0"
            style="height: 750px;"
            loading="lazy"
          ></iframe>
        </div>

        <!-- Mobile : lien -->
        <div class="md:hidden bg-white border border-neutral-200 rounded-lg p-6 text-center mb-4">
          <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <p class="text-neutral-600 text-sm mb-4">Les statistiques sont plus lisibles sur un écran large.</p>
          <a href={umamiShareUrl}
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center gap-2 bg-accent-600 text-white font-semibold py-2.5 px-5 rounded hover:bg-accent-700 transition-colors min-h-[44px] text-sm">
            Voir mes statistiques
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>

        <!-- Always visible link -->
        <div class="text-center">
          <a href={umamiShareUrl}
             target="_blank"
             rel="noopener noreferrer"
             class="text-sm text-primary-700 hover:text-primary-900 underline transition-colors">
            Ouvrir les statistiques dans un nouvel onglet
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer contact -->
  <footer class="border-t border-neutral-200 py-4 text-center text-sm text-neutral-500">
    Besoin d'aide ? <a href="mailto:marc@muller.im" class="text-primary-700 hover:text-primary-900 underline">marc@muller.im</a>
  </footer>
</BaseLayout>

<style is:inline>
  #panels { -ms-overflow-style: none; }
  #panels::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  // Tab/swipe sync
  const panels = document.getElementById('panels');
  const tabs = document.querySelectorAll('.tab-btn');
  const sections = panels.querySelectorAll('.tab-panel');

  function activateTab(index) {
    tabs.forEach((b, i) => {
      if (i === index) {
        b.classList.remove('text-neutral-500');
        b.classList.add('text-primary-700', 'bg-primary-50');
      } else {
        b.classList.remove('text-primary-700', 'bg-primary-50');
        b.classList.add('text-neutral-500');
      }
    });
  }

  tabs.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      activateTab(i);
    });
  });

  let scrollTimeout;
  panels.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const index = Math.round(panels.scrollLeft / panels.offsetWidth);
      activateTab(index);
    }, 50);
  }, { passive: true });

  // Copy review link
  const copyBtn = document.getElementById('copy-btn');
  const reviewInput = document.getElementById('review-link');
  const feedback = document.getElementById('copy-feedback');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(reviewInput.value);
      feedback.classList.remove('hidden');
      copyBtn.textContent = 'Copié !';
      setTimeout(() => {
        feedback.classList.add('hidden');
        copyBtn.textContent = 'Copier';
      }, 2000);
    } catch {
      reviewInput.select();
      document.execCommand('copy');
      feedback.classList.remove('hidden');
      setTimeout(() => feedback.classList.add('hidden'), 2000);
    }
  });
</script>
