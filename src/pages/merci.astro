---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Merci — Le Refuge"
  description="Votre message a bien été envoyé. Nous vous répondrons sous 24 heures."
  noindex={true}
>
  <Header slot="header" />

  <section class="min-h-[60vh] flex items-center justify-center px-4 pt-24">
    <div class="text-center max-w-lg">
      <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h1 class="font-heading text-3xl font-bold text-primary-900 mb-4">
        Merci pour votre message !
      </h1>
      <p class="text-neutral-700 mb-8">
        Nous avons bien reçu votre demande. Manon ou François vous répondra sous 24 heures.
        En attendant, suivez nos actualités sur Instagram.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://www.instagram.com/le_refuge_63/"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex items-center justify-center bg-accent-600 text-white font-semibold py-3 px-6 rounded hover:bg-accent-700 transition-colors min-h-[44px]">
          Suivez-nous sur Instagram
        </a>
        <a href="/"
           class="inline-flex items-center justify-center border-2 border-primary-600 text-primary-700 font-semibold py-3 px-6 rounded hover:bg-primary-50 transition-colors min-h-[44px]">
          Retour à l'accueil
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
