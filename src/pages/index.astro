---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import Hero from '@components/sections/Hero.astro';
import Restaurant from '@components/sections/Restaurant.astro';
import Chambres from '@components/sections/Chambres.astro';
import Gite from '@components/sections/Gite.astro';
import About from '@components/sections/About.astro';
import Gallery from '@components/sections/Gallery.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import FAQ from '@components/sections/FAQ.astro';
import Contact from '@components/sections/Contact.astro';
import { business } from '@data/business';
import {
  getRestaurantSchema,
  getLodgingBusinessSchema,
  getWebsiteSchema,
  getBreadcrumbSchema,
  getSpeakableSchema,
} from '@data/schemas';

// Schemas centralises — doctrine C1 wf-00-cms §7
const restaurantSchema = getRestaurantSchema();
const lodgingSchema = getLodgingBusinessSchema();
const websiteSchema = getWebsiteSchema();
const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: business.siteUrl },
]);
const speakableSchema = getSpeakableSchema();
---

<BaseLayout
  title="Le Refuge — Restaurant & Maison d'hôtes à Biollet | Combrailles, Auvergne"
  description="Restaurant de produits locaux, chambres d'hôtes et gîte à Biollet (63640). Cuisine du jardin, cadre nature, 3 chambres dès 54€/nuit. Réservation obligatoire."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(lodgingSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
  </Fragment>

  <Header slot="header" />

  <Hero />
  <Restaurant />
  <Chambres />
  <Gite />
  <About />
  <Gallery />
  <Testimonials />
  <FAQ />
  <Contact />

  <!-- Sticky CTA mobile -->
  <div class="fixed bottom-0 left-0 right-0 z-30 md:hidden bg-primary-900 border-t border-primary-800 px-4 py-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]">
    <a href="#contact" class="flex items-center justify-center gap-2 bg-accent-600 text-white font-semibold py-3 px-6 rounded hover:bg-accent-700 transition-colors min-h-[44px] w-full">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
      </svg>
      Je réserve
    </a>
  </div>

  <Footer slot="footer" />
</BaseLayout>
