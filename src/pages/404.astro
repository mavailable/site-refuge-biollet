---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Page introuvable — Le Refuge"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
>
  <Header slot="header" />

  <section class="min-h-[60vh] flex items-center justify-center px-4 pt-24">
    <div class="text-center max-w-lg">
      <p class="text-6xl font-bold text-primary-200 mb-4">404</p>
      <h1 class="font-heading text-3xl font-bold text-primary-900 mb-4">
        Cette page n'existe pas
      </h1>
      <p class="text-neutral-700 mb-8">
        La page que vous cherchez a peut-être été déplacée ou n'existe plus.
      </p>
      <a href="/"
         class="inline-flex items-center justify-center bg-accent-600 text-white font-semibold py-3 px-6 rounded hover:bg-accent-700 transition-colors min-h-[44px] mb-8">
        Retour à l'accueil
      </a>
      <nav class="flex flex-wrap justify-center gap-4 text-sm" aria-label="Liens utiles">
        <a href="/#restaurant" class="text-primary-700 hover:text-primary-900 transition-colors">Restaurant</a>
        <a href="/#chambres" class="text-primary-700 hover:text-primary-900 transition-colors">Chambres</a>
        <a href="/#gite" class="text-primary-700 hover:text-primary-900 transition-colors">Gîte</a>
        <a href="/#contact" class="text-primary-700 hover:text-primary-900 transition-colors">Contact</a>
      </nav>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
