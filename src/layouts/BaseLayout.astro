---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = '/images/og-image.jpg',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- OG Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Le Refuge" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Canonical + Favicon -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#4E8A3A" />

    <!-- Font preload -->
    <link rel="preload" as="font" href="/fonts/lora-v37-latin-700.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/dm-sans-v17-latin-regular.woff2" type="font/woff2" crossorigin />

    <title>{title}</title>

    <!-- Umami Analytics — sans cookies, RGPD-exempt -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="UMAMI_WEBSITE_ID"></script>

    <slot name="head" />
  </head>
  <body class="bg-neutral-50 text-neutral-700">
    <!-- Skip-to-content : WCAG 2.1 AA -->
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent-600 focus:text-white focus:px-4 focus:py-2 focus:rounded">
      Aller au contenu principal
    </a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />

    <!-- CMS inline editing (visible uniquement pour les admins connectes) -->
    <script>
      // cms_logged_in : charge le script d'edition visuelle si cookie CMS present
      if (document.cookie.includes('cms_session=')) {
        const s = document.createElement('script');
        s.src = '/cms-edit.js';
        s.defer = true;
        document.body.appendChild(s);
      }
    </script>
  </body>
</html>
